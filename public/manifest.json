{
  "name": "TapWatch - Barangay Incident Reporting System",
  "short_name": "Tap-Watch",
  "description": "Community incident reporting and emergency response system for Barangay Tapinac",
  "start_url": "/",
  "scope": "/",
  "display": "standalone",
  "background_color": "#ffffff",
  "theme_color": "#0f172a",
  "orientation": "any",
  "categories": ["utilities", "productivity", "government"],
  "lang": "en-US",
  "dir": "ltr",
  "icons": [
    {
      "src": "/Tapinac.logo.jpg",
      "sizes": "192x192",
      "type": "image/jpeg",
      "purpose": "any maskable"
    },
    {
      "src": "/Tapinac.logo.jpg",
      "sizes": "512x512",
      "type": "image/jpeg",
      "purpose": "any maskable"
    }
  ],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Report Incident",
      "short_name": "Report",
      "description": "Quickly report a new incident",
      "url": "/report",
      "icons": [
        {
          "src": "/Tapinac.logo.jpg",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "View Map",
      "short_name": "Map",
      "description": "View incident map",
      "url": "/map",
      "icons": [
        {
          "src": "/Tapinac.logo.jpg",
          "sizes": "192x192"
        }
      ]
    },
    {
      "name": "Dashboard",
      "short_name": "Dashboard",
      "description": "View your dashboard",
      "url": "/dashboard",
      "icons": [
        {
          "src": "/Tapinac.logo.jpg",
          "sizes": "192x192"
        }
      ]
    }
  ],
  "share_target": {
    "action": "/report",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "description",
      "files": [
        {
          "name": "media",
          "accept": ["image/*", "video/*"]
        }
      ]
    }
  },
  "prefer_related_applications": false
}
